{
  "info": {
    "name": "User Profile Management",
    "description": "API endpoints for managing user profiles in the RFQ system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "12345"
  },
  "auth": {
    "type": "bearer",
