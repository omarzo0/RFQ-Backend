generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model admins {
  id                                                    String                  @id
  email                                                 String                  @unique
  password_hash                                         String
  first_name                                            String
  last_name                                             String
  role                                                  AdminRole               @default(ADMIN)
  is_active                                             Boolean                 @default(true)
  last_login_at                                         DateTime?
  created_at                                            DateTime                @default(now())
  updated_at                                            DateTime
  company_warnings_company_warnings_issued_byToadmins   company_warnings[]      @relation("company_warnings_issued_byToadmins")
  company_warnings_company_warnings_resolved_byToadmins company_warnings[]      @relation("company_warnings_resolved_byToadmins")
  notifications                                         notifications[]
  password_reset_tokens                                 password_reset_tokens[]
  refresh_tokens                                        refresh_tokens[]
  support_tickets                                       support_tickets[]
}

model ai_processing_logs {
  id               String           @id
  company_id       String
  email_reply_id   String?
  processing_type  ProcessingType
  input_data       Json
  output_data      Json?
  confidence_score Decimal?         @db.Decimal(3, 2)
  processing_time  Int?
  status           ProcessingStatus @default(PENDING)
  error_message    String?
  model_version    String?
  cost             Decimal?         @db.Decimal(10, 4)
  tokens_used      Int?
  created_at       DateTime         @default(now())
  companies        companies        @relation(fields: [company_id], references: [id], onDelete: Cascade)
  email_replies    email_replies?   @relation(fields: [email_reply_id], references: [id])
}

model api_keys {
  id                  String        @id
  company_id          String
  key_name            String
  api_key             String        @unique
  scopes              String[]
  rate_limit_per_hour Int           @default(1000)
  is_active           Boolean       @default(true)
  last_used_at        DateTime?
  expires_at          DateTime?
  created_by          String
  created_at          DateTime      @default(now())
  companies           companies     @relation(fields: [company_id], references: [id], onDelete: Cascade)
  company_users       company_users @relation(fields: [created_by], references: [id])
}

model bulk_emails {
  id                    String           @id
  company_id            String
  name                  String
  description           String?
  subject               String
  body_html             String
  body_text             String?
  template_id           String?
  contact_ids           String[]
  total_recipients      Int              @default(0)
  sent_count            Int              @default(0)
  delivered_count       Int              @default(0)
  opened_count          Int              @default(0)
  clicked_count         Int              @default(0)
  bounced_count         Int              @default(0)
  failed_count          Int              @default(0)
  status                BulkEmailStatus  @default(DRAFT)
  scheduled_for         DateTime?
  started_at            DateTime?
  completed_at          DateTime?
  rate_limit_per_minute Int              @default(10)
  personalization_data  Json?
  language              String           @default("en")
  timezone              String?
  created_by            String
  created_at            DateTime         @default(now())
  updated_at            DateTime
  companies             companies        @relation(fields: [company_id], references: [id], onDelete: Cascade)
  company_users         company_users    @relation(fields: [created_by], references: [id])
  email_templates       email_templates? @relation(fields: [template_id], references: [id])
  email_logs            email_logs[]
}

model carrier_performance_metrics {
  id                          String         @id
  company_id                  String
  shipping_line_id            String
  period_start                DateTime
  period_end                  DateTime
  period_type                 String
  rfqs_received               Int            @default(0)
  quotes_submitted            Int            @default(0)
  response_rate               Decimal        @default(0) @db.Decimal(5, 2)
  average_response_time_hours Decimal?       @db.Decimal(8, 2)
  quotes_won                  Int            @default(0)
  win_rate                    Decimal        @default(0) @db.Decimal(5, 2)
  average_quote_amount        Decimal?       @db.Decimal(12, 2)
  calculated_at               DateTime       @default(now())
  companies                   companies      @relation(fields: [company_id], references: [id], onDelete: Cascade)
  shipping_lines              shipping_lines @relation(fields: [shipping_line_id], references: [id], onDelete: Cascade)

  @@unique([company_id, shipping_line_id, period_start, period_end, period_type])
}

model companies {
  id                          String                        @id
  name                        String
  email                       String                        @unique
  domain                      String?
  phone                       String?
  address                     String?
  city                        String?
  country                     String?
  timezone                    String                        @default("UTC")
  subscription_plan           String                        @default("trial")
  subscription_status         SubscriptionStatus            @default(ACTIVE)
  stripe_customer_id          String?
  trial_ends_at               DateTime?
  email_footer                String?
  default_follow_up_days      Int                           @default(3)
  auto_follow_up_enabled      Boolean                       @default(true)
  is_active                   Boolean                       @default(true)
  created_at                  DateTime                      @default(now())
  updated_at                  DateTime
  stripe_subscription_id      String?
  payment_deadline            DateTime?
  pending_plan_id             String?
  ai_processing_logs          ai_processing_logs[]
  api_keys                    api_keys[]
  bulk_emails                 bulk_emails[]
  carrier_performance_metrics carrier_performance_metrics[]
  company_features            company_features[]
  company_users               company_users[]
  company_warnings            company_warnings[]
  contacts                    contacts[]
  email_campaigns             email_campaigns[]
  email_logs                  email_logs[]
  email_replies               email_replies[]
  email_templates             email_templates[]
  email_unsubscribes          email_unsubscribes[]
  email_webhooks              email_webhooks[]
  financial_details           financial_details?
  follow_up_rules             follow_up_rules[]
  imap_configurations         imap_configurations[]
  notifications               notifications[]
  parsing_learning_data       parsing_learning_data[]
  password_reset_tokens       password_reset_tokens[]
  refresh_tokens              refresh_tokens[]
  rfq_templates               rfq_templates[]
  rfqs                        rfqs[]
  route_performance_metrics   route_performance_metrics[]
  shipping_lines              shipping_lines[]
  support_tickets             support_tickets[]
  transactions                transactions[]
  usage_metrics               usage_metrics[]
  webhook_endpoints           webhook_endpoints[]
}

model company_features {
  id                String          @id
  company_id        String
  system_feature_id String
  is_enabled        Boolean         @default(false)
  custom_settings   Json?
  created_at        DateTime        @default(now())
  updated_at        DateTime
  companies         companies       @relation(fields: [company_id], references: [id], onDelete: Cascade)
  system_features   system_features @relation(fields: [system_feature_id], references: [id], onDelete: Cascade)

  @@unique([company_id, system_feature_id])
}

model company_users {
  id                                       String                  @id
  company_id                               String
  email                                    String
  password_hash                            String
  first_name                               String
  last_name                                String
  role                                     UserRole                @default(EMPLOYEE)
  is_active                                Boolean                 @default(true)
  last_login_at                            DateTime?
  created_at                               DateTime                @default(now())
  updated_at                               DateTime
  api_keys                                 api_keys[]
  bulk_emails                              bulk_emails[]
  companies                                companies               @relation(fields: [company_id], references: [id], onDelete: Cascade)
  contacts                                 contacts[]
  email_campaigns                          email_campaigns[]
  email_parsing_results                    email_parsing_results[]
  email_replies                            email_replies[]
  email_templates                          email_templates[]
  email_webhooks                           email_webhooks[]
  follow_up_rules                          follow_up_rules[]
  imap_configurations                      imap_configurations[]
  parsing_learning_data                    parsing_learning_data[]
  password_reset_tokens                    password_reset_tokens[]
  quotes_quotes_awarded_byTocompany_users  quotes[]                @relation("quotes_awarded_byTocompany_users")
  quotes_quotes_created_byTocompany_users  quotes[]                @relation("quotes_created_byTocompany_users")
  quotes_quotes_verified_byTocompany_users quotes[]                @relation("quotes_verified_byTocompany_users")
  refresh_tokens                           refresh_tokens[]
  rfq_templates                            rfq_templates[]
  rfqs_rfqs_assigned_toTocompany_users     rfqs[]                  @relation("rfqs_assigned_toTocompany_users")
  rfqs_rfqs_created_byTocompany_users      rfqs[]                  @relation("rfqs_created_byTocompany_users")
  shipping_lines                           shipping_lines[]
  webhook_endpoints                        webhook_endpoints[]

  @@unique([company_id, email])
}

model company_warnings {
  id                                          String          @id
  company_id                                  String
  title                                       String
  reason                                      String
  severity                                    WarningSeverity @default(MODERATE)
  category                                    WarningCategory @default(GENERAL)
  issued_by                                   String
  issued_at                                   DateTime        @default(now())
  expires_at                                  DateTime?
  is_resolved                                 Boolean         @default(false)
  resolved_at                                 DateTime?
  resolved_by                                 String?
  action_required                             String?
  notes                                       String?
  companies                                   companies       @relation(fields: [company_id], references: [id], onDelete: Cascade)
  admins_company_warnings_issued_byToadmins   admins          @relation("company_warnings_issued_byToadmins", fields: [issued_by], references: [id])
  admins_company_warnings_resolved_byToadmins admins?         @relation("company_warnings_resolved_byToadmins", fields: [resolved_by], references: [id])

  @@index([company_id, is_resolved])
  @@index([severity, is_resolved])
}

model contacts {
  id                    String                 @id
  company_id            String
  shipping_line_id      String
  first_name            String
  last_name             String
  email                 String
  phone                 String?
  job_title             String?
  department            String?
  tags                  String[]
  notes                 String?
  performance_score     Int                    @default(0)
  do_not_contact        Boolean                @default(false)
  is_primary            Boolean                @default(false)
  is_active             Boolean                @default(true)
  is_archived           Boolean                @default(false)
  created_by            String
  created_at            DateTime               @default(now())
  updated_at            DateTime
  avg_response_time     Int?
  communication_history String?
  last_response_at      DateTime?
  preferences           String?
  quote_quality         Int?
  reliability           Int?
  response_rate         Float?
  seniority             String?
  specialization        String?
  total_responses       Int                    @default(0)
  total_rfqs_sent       Int                    @default(0)
  company_name          String?
  companies             companies              @relation(fields: [company_id], references: [id], onDelete: Cascade)
  company_users         company_users          @relation(fields: [created_by], references: [id])
  shipping_lines        shipping_lines         @relation(fields: [shipping_line_id], references: [id], onDelete: Cascade)
  email_logs            email_logs[]
  email_replies         email_replies[]
  quotes                quotes[]
  rfq_recipients        rfq_recipients[]
  scheduled_follow_ups  scheduled_follow_ups[]

  @@unique([company_id, shipping_line_id, email])
}

model email_attachments {
  id                String        @id
  email_reply_id    String
  filename          String
  original_filename String
  mime_type         String
  size              Int
  content           String
  file_path         String?
  is_processed      Boolean       @default(false)
  processing_status String?
  extracted_text    String?
  created_at        DateTime      @default(now())
  email_replies     email_replies @relation(fields: [email_reply_id], references: [id], onDelete: Cascade)
}

model email_bounces {
  id            String     @id
  email_log_id  String
  bounce_type   BounceType
  bounce_reason String?
  bounce_code   String?
  bounced_at    DateTime   @default(now())
  is_permanent  Boolean    @default(false)
  email_logs    email_logs @relation(fields: [email_log_id], references: [id], onDelete: Cascade)
}

model email_campaigns {
  id               String         @id
  company_id       String
  name             String
  description      String?
  campaign_type    CampaignType   @default(RFQ_BLAST)
  status           CampaignStatus @default(DRAFT)
  start_date       DateTime?
  end_date         DateTime?
  total_emails     Int            @default(0)
  sent_emails      Int            @default(0)
  delivered_emails Int            @default(0)
  opened_emails    Int            @default(0)
  clicked_emails   Int            @default(0)
  bounced_emails   Int            @default(0)
  failed_emails    Int            @default(0)
  response_rate    Float?
  open_rate        Float?
  click_rate       Float?
  created_by       String
  created_at       DateTime       @default(now())
  updated_at       DateTime
  companies        companies      @relation(fields: [company_id], references: [id], onDelete: Cascade)
  company_users    company_users  @relation(fields: [created_by], references: [id])
  email_logs       email_logs[]
}

model email_engagements {
  id              String         @id
  email_log_id    String
  engagement_type EngagementType
  timestamp       DateTime       @default(now())
  user_agent      String?
  ip_address      String?
  location        String?
  device          String?
  browser         String?
  os              String?
  link_url        String?
  link_text       String?
  email_logs      email_logs     @relation(fields: [email_log_id], references: [id], onDelete: Cascade)
}

model email_logs {
  id                     String                @id
  company_id             String
  to_email               String
  from_email             String
  subject                String
  body_html              String?
  body_text              String?
  message_id             String?
  status                 EmailStatus           @default(QUEUED)
  rfq_id                 String?
  contact_id             String?
  template_id            String?
  queued_at              DateTime              @default(now())
  sent_at                DateTime?
  delivered_at           DateTime?
  opened_at              DateTime?
  clicked_at             DateTime?
  bounced_at             DateTime?
  failed_at              DateTime?
  error_message          String?
  retry_count            Int                   @default(0)
  created_at             DateTime              @default(now())
  bulk_email_id          String?
  campaign_id            String?
  email_type             EmailType             @default(RFQ)
  follow_up_rule_id      String?
  is_bulk_email          Boolean               @default(false)
  language               String                @default("en")
  max_retries            Int                   @default(3)
  next_retry_at          DateTime?
  personalization_data   Json?
  priority               EmailPriority         @default(NORMAL)
  scheduled_follow_up_id String?
  scheduled_for          DateTime?
  timezone               String?
  tracking_pixel_id      String?
  unsubscribe_token      String?
  email_bounces          email_bounces[]
  email_engagements      email_engagements[]
  bulk_emails            bulk_emails?          @relation(fields: [bulk_email_id], references: [id])
  email_campaigns        email_campaigns?      @relation(fields: [campaign_id], references: [id])
  companies              companies             @relation(fields: [company_id], references: [id], onDelete: Cascade)
  contacts               contacts?             @relation(fields: [contact_id], references: [id])
  follow_up_rules        follow_up_rules?      @relation(fields: [follow_up_rule_id], references: [id])
  rfqs                   rfqs?                 @relation(fields: [rfq_id], references: [id])
  scheduled_follow_ups   scheduled_follow_ups? @relation(fields: [scheduled_follow_up_id], references: [id])
  email_templates        email_templates?      @relation(fields: [template_id], references: [id])
}

model email_parsing_results {
  id                String           @id
  email_reply_id    String
  parsing_type      ParsingType
  extracted_data    Json
  confidence_score  Decimal          @db.Decimal(3, 2)
  raw_text          String?
  processed_text    String?
  validation_status ValidationStatus @default(PENDING)
  validation_notes  String?
  is_validated      Boolean          @default(false)
  validated_by      String?
  validated_at      DateTime?
  created_at        DateTime         @default(now())
  updated_at        DateTime
  email_replies     email_replies    @relation(fields: [email_reply_id], references: [id], onDelete: Cascade)
  company_users     company_users?   @relation(fields: [validated_by], references: [id])
}

model email_replies {
  id                    String                  @id
  company_id            String
  message_id            String                  @unique
  in_reply_to           String?
  references            String[]
  thread_id             String?
  from_email            String
  from_name             String?
  to_email              String
  subject               String
  body_html             String?
  body_text             String?
  received_at           DateTime
  processed_at          DateTime?
  status                ReplyStatus             @default(RECEIVED)
  source                ReplySource             @default(IMAP)
  raw_content           String?
  headers               Json?
  rfq_id                String?
  contact_id            String?
  shipping_line_id      String?
  quote_id              String?
  confidence_score      Decimal?                @db.Decimal(3, 2)
  requires_review       Boolean                 @default(false)
  review_notes          String?
  reviewed_by           String?
  reviewed_at           DateTime?
  created_at            DateTime                @default(now())
  updated_at            DateTime
  ai_processing_logs    ai_processing_logs[]
  email_attachments     email_attachments[]
  email_parsing_results email_parsing_results[]
  companies             companies               @relation(fields: [company_id], references: [id], onDelete: Cascade)
  contacts              contacts?               @relation(fields: [contact_id], references: [id])
  quotes                quotes?                 @relation(fields: [quote_id], references: [id])
  company_users         company_users?          @relation(fields: [reviewed_by], references: [id])
  rfqs                  rfqs?                   @relation(fields: [rfq_id], references: [id])
  shipping_lines        shipping_lines?         @relation(fields: [shipping_line_id], references: [id])
}

model email_templates {
  id               String            @id
  company_id       String
  name             String
  template_type    String
  subject          String
  body_html        String
  body_text        String?
  supported_tokens String[]
  language         String            @default("en")
  is_default       Boolean           @default(false)
  is_active        Boolean           @default(true)
  created_by       String
  created_at       DateTime          @default(now())
  updated_at       DateTime
  bulk_emails      bulk_emails[]
  email_logs       email_logs[]
  companies        companies         @relation(fields: [company_id], references: [id], onDelete: Cascade)
  company_users    company_users     @relation(fields: [created_by], references: [id])
  follow_up_rules  follow_up_rules[]

  @@unique([company_id, name])
}

model email_unsubscribes {
  id                String    @id
  company_id        String
  email             String
  unsubscribe_token String    @unique
  reason            String?
  unsubscribed_at   DateTime  @default(now())
  companies         companies @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([company_id, email])
}

model email_webhooks {
  id                 String        @id
  company_id         String
  name               String
  provider           String
  webhook_url        String
  secret             String?
  is_active          Boolean       @default(true)
  last_received_at   DateTime?
  last_error_at      DateTime?
  last_error_message String?
  total_received     Int           @default(0)
  total_processed    Int           @default(0)
  total_failed       Int           @default(0)
  created_by         String
  created_at         DateTime      @default(now())
  updated_at         DateTime
  companies          companies     @relation(fields: [company_id], references: [id], onDelete: Cascade)
  company_users      company_users @relation(fields: [created_by], references: [id])
}

model financial_details {
  id                        String    @id
  company_id                String    @unique
  total_revenue             Decimal   @default(0) @db.Decimal(12, 2)
  total_transactions        Int       @default(0)
  successful_transactions   Int       @default(0)
  failed_transactions       Int       @default(0)
  refunded_transactions     Int       @default(0)
  average_transaction_value Decimal   @default(0) @db.Decimal(12, 2)
  monthly_recurring_revenue Decimal   @default(0) @db.Decimal(12, 2)
  annual_recurring_revenue  Decimal   @default(0) @db.Decimal(12, 2)
  churn_rate                Decimal   @default(0) @db.Decimal(5, 2)
  customer_lifetime_value   Decimal   @default(0) @db.Decimal(12, 2)
  last_updated_at           DateTime  @default(now())
  created_at                DateTime  @default(now())
  updated_at                DateTime
  companies                 companies @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model follow_up_rules {
  id                   String                 @id
  company_id           String
  name                 String
  description          String?
  days_after_send      Int                    @default(3)
  only_if_not_opened   Boolean                @default(false)
  only_if_not_replied  Boolean                @default(true)
  max_follow_ups       Int                    @default(2)
  email_template_id    String?
  is_active            Boolean                @default(true)
  created_by           String
  created_at           DateTime               @default(now())
  updated_at           DateTime
  business_days_only   Boolean                @default(false)
  custom_schedule      Json?
  exclude_holidays     Boolean                @default(false)
  exclude_weekends     Boolean                @default(false)
  follow_up_intervals  Json?
  max_time_since_open  Int?
  min_time_since_open  Int?
  only_if_clicked      Boolean                @default(false)
  only_if_delivered    Boolean                @default(false)
  only_if_opened       Boolean                @default(false)
  schedule_type        ScheduleType           @default(IMMEDIATE)
  specific_time        String?
  timezone             String?                @default("UTC")
  email_logs           email_logs[]
  companies            companies              @relation(fields: [company_id], references: [id], onDelete: Cascade)
  company_users        company_users          @relation(fields: [created_by], references: [id])
  email_templates      email_templates?       @relation(fields: [email_template_id], references: [id])
  scheduled_follow_ups scheduled_follow_ups[]
}

model imap_configurations {
  id                   String        @id
  company_id           String
  name                 String
  host                 String
  port                 Int
  secure               Boolean       @default(true)
  username             String
  password             String
  folder               String        @default("INBOX")
  is_active            Boolean       @default(true)
  last_checked_at      DateTime?
  last_error_at        DateTime?
  last_error_message   String?
  check_interval       Int           @default(300)
  max_emails_per_check Int           @default(50)
  created_by           String
  created_at           DateTime      @default(now())
  updated_at           DateTime
  companies            companies     @relation(fields: [company_id], references: [id], onDelete: Cascade)
  company_users        company_users @relation(fields: [created_by], references: [id])
}

model notifications {
  id           String               @id
  title        String
  message      String
  type         NotificationType     @default(INFO)
  priority     NotificationPriority @default(NORMAL)
  company_id   String?
  is_global    Boolean              @default(false)
  is_read      Boolean              @default(false)
  created_by   String
  created_at   DateTime             @default(now())
  read_at      DateTime?
  expires_at   DateTime?
  action_url   String?
  action_label String?
  companies    companies?           @relation(fields: [company_id], references: [id], onDelete: Cascade)
  admins       admins               @relation(fields: [created_by], references: [id])

  @@index([company_id, is_read])
  @@index([is_global, created_at])
}

model parsing_learning_data {
  id               String         @id
  company_id       String
  original_text    String
  extracted_data   Json
  corrected_data   Json?
  confidence_score Decimal        @db.Decimal(3, 2)
  is_corrected     Boolean        @default(false)
  correction_notes String?
  corrected_by     String?
  corrected_at     DateTime?
  parsing_type     ParsingType
  created_at       DateTime       @default(now())
  companies        companies      @relation(fields: [company_id], references: [id], onDelete: Cascade)
  company_users    company_users? @relation(fields: [corrected_by], references: [id])
}

model password_reset_tokens {
  id              String         @id
  token_hash      String         @unique
  admin_user_id   String?
  company_user_id String?
  user_type       UserType
  company_id      String?
  email           String
  expires_at      DateTime
  is_used         Boolean        @default(false)
  used_at         DateTime?
  created_at      DateTime       @default(now())
  admins          admins?        @relation(fields: [admin_user_id], references: [id], onDelete: Cascade)
  companies       companies?     @relation(fields: [company_id], references: [id], onDelete: Cascade)
  company_users   company_users? @relation(fields: [company_user_id], references: [id], onDelete: Cascade)
}

model quotes {
  id                                              String          @id
  rfq_id                                          String
  contact_id                                      String
  shipping_line_id                                String
  quote_reference                                 String?
  ocean_freight                                   Decimal?        @db.Decimal(12, 2)
  currency                                        String          @default("USD")
