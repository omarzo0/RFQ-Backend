generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id             String          @id @default(uuid())
  email          String          @unique
  passwordHash   String          @map("password_hash")
  firstName      String          @map("first_name")
  lastName       String          @map("last_name")
  role           AdminRole       @default(ADMIN)
  isActive       Boolean         @default(true) @map("is_active")
  lastLoginAt    DateTime?       @map("last_login_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  refreshTokens  RefreshToken[]
  supportTickets SupportTicket[] @relation("AssignedTickets")

  @@map("admins")
}

model Company {
  id                  String                     @id @default(uuid())
  name                String
  email               String                     @unique
  domain              String?
  phone               String?
  address             String?
  city                String?
  country             String?
  timezone            String                     @default("UTC")
  subscriptionPlan    String                     @default("trial") @map("subscription_plan")
  subscriptionStatus  SubscriptionStatus         @default(ACTIVE) @map("subscription_status")
  stripeCustomerId    String?                    @map("stripe_customer_id")
  trialEndsAt         DateTime?                  @map("trial_ends_at")
  emailFooter         String?                    @map("email_footer")
  defaultFollowUpDays Int                        @default(3) @map("default_follow_up_days")
  autoFollowUpEnabled Boolean                    @default(true) @map("auto_follow_up_enabled")
  isActive            Boolean                    @default(true) @map("is_active")
  createdAt           DateTime                   @default(now()) @map("created_at")
  updatedAt           DateTime                   @updatedAt @map("updated_at")
  apiKeys             APIKey[]
  carrierMetrics      CarrierPerformanceMetric[]
  users               CompanyUser[]
  contacts            Contact[]
  emailLogs           EmailLog[]
  emailTemplates      EmailTemplate[]
  followUpRules       FollowUpRule[]
  refreshTokens       RefreshToken[]
  rfqTemplates        RFQTemplate[]
  rfqs                RFQ[]
  routeMetrics        RoutePerformanceMetric[]
  shippingLines       ShippingLine[]
  supportTickets      SupportTicket[]
  usageMetrics        UsageMetric[]
  webhookEndpoints    WebhookEndpoint[]
  bulkEmails          BulkEmail[]
  emailCampaigns      EmailCampaign[]
  emailUnsubscribes   EmailUnsubscribe[]
  emailReplies        EmailReply[]
  imapConfigurations  IMAPConfiguration[]
  emailWebhooks       EmailWebhook[]
  aiProcessingLogs    AIProcessingLog[]
  parsingLearningData ParsingLearningData[]
  companyFeatures     CompanyFeature[]

  @@map("companies")
}

model CompanyUser {
  id                    String            @id @default(uuid())
  companyId             String            @map("company_id")
  email                 String
  passwordHash          String            @map("password_hash")
  firstName             String            @map("first_name")
  lastName              String            @map("last_name")
  role                  UserRole          @default(EMPLOYEE)
  isActive              Boolean           @default(true) @map("is_active")
  lastLoginAt           DateTime?         @map("last_login_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  createdAPIKeys        APIKey[]
  company               Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdContacts       Contact[]
  createdEmailTemplates EmailTemplate[]
  createdFollowUpRules  FollowUpRule[]
  awardedQuotes         Quote[]           @relation("QuoteAwarder")
  createdQuotes         Quote[]
  verifiedQuotes        Quote[]           @relation("QuoteVerifier")
  refreshTokens         RefreshToken[]
  createdTemplates      RFQTemplate[]
  assignedRFQs          RFQ[]             @relation("RFQAssignee")
  createdRFQs           RFQ[]             @relation("RFQCreator")
  createdShippingLines  ShippingLine[]
  createdWebhooks       WebhookEndpoint[]
  createdBulkEmails     BulkEmail[]
  createdEmailCampaigns EmailCampaign[]
  createdIMAPConfigs    IMAPConfiguration[]
  createdEmailWebhooks  EmailWebhook[]
  reviewedEmailReplies  EmailReply[]
  validatedParsingResults EmailParsingResult[]
  correctedLearningData ParsingLearningData[]

  @@unique([companyId, email])
  @@map("company_users")
}

model RefreshToken {
  id            String       @id @default(uuid())
  tokenHash     String       @map("token_hash")
  adminUserId   String?      @map("admin_user_id")
  companyUserId String?      @map("company_user_id")
  userType      UserType     @map("user_type")
  companyId     String?      @map("company_id")
  expiresAt     DateTime     @map("expires_at")
  isRevoked     Boolean      @default(false) @map("is_revoked")
  createdAt     DateTime     @default(now()) @map("created_at")
  admin         Admin?       @relation(fields: [adminUserId], references: [id])
  company       Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyUser   CompanyUser? @relation(fields: [companyUserId], references: [id])

  @@map("refresh_tokens")
}

model ShippingLine {
  id                   String                     @id @default(uuid())
  companyId            String                     @map("company_id")
  name                 String
  code                 String?
  website              String?
  headquartersLocation String?                    @map("headquarters_location")
  description          String?
  isActive             Boolean                    @default(true) @map("is_active")
  isArchived           Boolean                    @default(false) @map("is_archived")
  createdBy            String                     @map("created_by")
  createdAt            DateTime                   @default(now()) @map("created_at")
  updatedAt            DateTime                   @updatedAt @map("updated_at")
  headquartersCountry  String?                    @map("headquarters_country")
  isCustom             Boolean                    @default(false) @map("is_custom")
  notes                String?
  reliability          Int?
  scacCode             String?                    @map("scac_code")
  serviceQuality       Int?
  services             String[]
  specialization       String?
  tags                 String[]
  tradeLanes           String[]                   @map("trade_lanes")
  carrierMetrics       CarrierPerformanceMetric[]
  contacts             Contact[]
  quotes               Quote[]
  rfqRecipients        RFQRecipient[]
  routeMetrics         RoutePerformanceMetric[]
  company              Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator              CompanyUser                @relation(fields: [createdBy], references: [id])
  emailReplies         EmailReply[]

  @@unique([companyId, name])
  @@map("shipping_lines")
}

model Contact {
  id                   String              @id @default(uuid())
  companyId            String              @map("company_id")
  shippingLineId       String              @map("shipping_line_id")
  firstName            String              @map("first_name")
  lastName             String              @map("last_name")
  email                String
  phone                String?
  jobTitle             String?             @map("job_title")
  department           String?
  tags                 String[]
  notes                String?
  performanceScore     Int                 @default(0) @map("performance_score")
  doNotContact         Boolean             @default(false) @map("do_not_contact")
  isPrimary            Boolean             @default(false) @map("is_primary")
  isActive             Boolean             @default(true) @map("is_active")
  isArchived           Boolean             @default(false) @map("is_archived")
  createdBy            String              @map("created_by")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  avgResponseTime      Int?                @map("avg_response_time")
  communicationHistory String?             @map("communication_history")
  lastResponseAt       DateTime?           @map("last_response_at")
  preferences          String?
  quoteQuality         Int?                @map("quote_quality")
  reliability          Int?
  responseRate         Float?              @map("response_rate")
  seniority            String?
  specialization       String?
  totalResponses       Int                 @default(0) @map("total_responses")
  totalRFQsSent        Int                 @default(0) @map("total_rfqs_sent")
  company              Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator              CompanyUser         @relation(fields: [createdBy], references: [id])
  shippingLine         ShippingLine        @relation(fields: [shippingLineId], references: [id], onDelete: Cascade)
  emailLogs            EmailLog[]
  quotes               Quote[]
  rfqRecipients        RFQRecipient[]
  scheduledFollowUps   ScheduledFollowUp[]
  emailReplies         EmailReply[]

  @@unique([companyId, shippingLineId, email])
  @@map("contacts")
}

model RFQTemplate {
  id                  String        @id @default(uuid())
  companyId           String        @map("company_id")
  name                String
  description         String?
  subjectTemplate     String        @map("subject_template")
  bodyTemplate        String        @map("body_template")
  originPort          String?       @map("origin_port")
  destinationPort     String?       @map("destination_port")
  commodity           String?
  containerType       String?       @map("container_type")
  containerQuantity   Int?          @map("container_quantity")
  cargoWeight         Decimal?      @map("cargo_weight") @db.Decimal(10, 2)
  cargoVolume         Decimal?      @map("cargo_volume") @db.Decimal(10, 2)
  incoterm            String?
  specialRequirements String?       @map("special_requirements")
  requiredServices    String[]      @map("required_services")
  isDefault           Boolean       @default(false) @map("is_default")
  createdBy           String        @map("created_by")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  category            String?
  dynamicFields       Json?         @map("dynamic_fields")
  isActive            Boolean       @default(true) @map("is_active")
  isPublic            Boolean       @default(false) @map("is_public")
  language            String        @default("en")
  lastUsedAt          DateTime?     @map("last_used_at")
  parentTemplateId    String?       @map("parent_template_id")
  tags                String[]
  templateVariables   String[]      @map("template_variables")
  tradeLane           String?       @map("trade_lane")
  usageCount          Int           @default(0) @map("usage_count")
  version             Int           @default(1)
  company             Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator             CompanyUser   @relation(fields: [createdBy], references: [id])
  parentTemplate      RFQTemplate?  @relation("TemplateInheritance", fields: [parentTemplateId], references: [id])
  childTemplates      RFQTemplate[] @relation("TemplateInheritance")

  @@map("rfq_templates")
}

model RFQ {
  id                  String              @id @default(uuid())
  companyId           String              @map("company_id")
  rfqNumber           String              @map("rfq_number")
  title               String
  description         String?
  originPort          String              @map("origin_port")
  destinationPort     String              @map("destination_port")
  commodity           String?
  containerType       String?             @map("container_type")
  containerQuantity   Int                 @default(1) @map("container_quantity")
  cargoWeight         Decimal?            @map("cargo_weight") @db.Decimal(10, 2)
  cargoVolume         Decimal?            @map("cargo_volume") @db.Decimal(10, 2)
  incoterm            String              @default("FOB")
  cargoReadyDate      DateTime?           @map("cargo_ready_date")
  quoteDeadline       DateTime?           @map("quote_deadline")
  shipmentUrgency     Urgency             @default(NORMAL) @map("shipment_urgency")
  specialRequirements String?             @map("special_requirements")
  requiredServices    String[]            @map("required_services")
  preferredCarriers   String[]            @map("preferred_carriers")
  emailSubject        String?             @map("email_subject")
  emailBody           String?             @map("email_body")
  status              RFQStatus           @default(DRAFT)
  sentAt              DateTime?           @map("sent_at")
  closedAt            DateTime?           @map("closed_at")
  totalContactsSent   Int                 @default(0) @map("total_contacts_sent")
  totalQuotesReceived Int                 @default(0) @map("total_quotes_received")
  bestQuoteAmount     Decimal?            @map("best_quote_amount") @db.Decimal(12, 2)
  averageQuoteAmount  Decimal?            @map("average_quote_amount") @db.Decimal(12, 2)
  createdBy           String              @map("created_by")
  assignedTo          String?             @map("assigned_to")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  currency            String              @default("USD")
  estimatedValue      Decimal?            @map("estimated_value") @db.Decimal(12, 2)
  notes               String?
  priority            Priority            @default(MEDIUM)
  responseRate        Float?              @map("response_rate")
  tags                String[]
  tradeLane           String?             @map("trade_lane")
  emailLogs           EmailLog[]
  quotes              Quote[]
  recipients          RFQRecipient[]
  assignedToUser      CompanyUser?        @relation("RFQAssignee", fields: [assignedTo], references: [id])
  company             Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUser       CompanyUser         @relation("RFQCreator", fields: [createdBy], references: [id])
  scheduledFollowUps  ScheduledFollowUp[]
  emailReplies        EmailReply[]

  @@unique([companyId, rfqNumber])
  @@map("rfqs")
}

model RFQRecipient {
  id                  String       @id @default(uuid())
  rfqId               String       @map("rfq_id")
  contactId           String       @map("contact_id")
  shippingLineId      String       @map("shipping_line_id")
  emailSentAt         DateTime     @map("email_sent_at")
  emailDeliveredAt    DateTime?    @map("email_delivered_at")
  emailOpenedAt       DateTime?    @map("email_opened_at")
  emailClickedAt      DateTime?    @map("email_clicked_at")
  lastEmailActivityAt DateTime?    @map("last_email_activity_at")
  hasResponded        Boolean      @default(false) @map("has_responded")
  responseReceivedAt  DateTime?    @map("response_received_at")
  createdAt           DateTime     @default(now()) @map("created_at")
  contact             Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  rfq                 RFQ          @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  shippingLine        ShippingLine @relation(fields: [shippingLineId], references: [id], onDelete: Cascade)

  @@unique([rfqId, contactId])
  @@map("rfq_recipients")
}

model Quote {
  id                    String       @id @default(uuid())
  rfqId                 String       @map("rfq_id")
  contactId             String       @map("contact_id")
  shippingLineId        String       @map("shipping_line_id")
  quoteReference        String?      @map("quote_reference")
  oceanFreight          Decimal?     @map("ocean_freight") @db.Decimal(12, 2)
  currency              String       @default("USD")
  baf                   Decimal?     @db.Decimal(12, 2)
  caf                   Decimal?     @db.Decimal(12, 2)
  securityFee           Decimal?     @map("security_fee") @db.Decimal(12, 2)
  documentationFee      Decimal?     @map("documentation_fee") @db.Decimal(12, 2)
  handlingCharges       Decimal?     @map("handling_charges") @db.Decimal(12, 2)
  otherCharges          Json?        @map("other_charges")
  totalAmount           Decimal      @map("total_amount") @db.Decimal(12, 2)
  validityDate          DateTime     @map("validity_date")
  paymentTerms          String?      @map("payment_terms")
  transitTime           String?      @map("transit_time")
  freeTimeAtOrigin      Int?         @map("free_time_at_origin")
  freeTimeAtDestination Int?         @map("free_time_at_destination")
  termsAndConditions    String?      @map("terms_and_conditions")
  specialNotes          String?      @map("special_notes")
  source                QuoteSource  @default(EMAIL)
  isParsedByAi          Boolean      @default(false) @map("is_parsed_by_ai")
  confidenceScore       Decimal?     @map("confidence_score") @db.Decimal(3, 2)
  rawEmailContent       String?      @map("raw_email_content")
  status                QuoteStatus  @default(ACTIVE)
  isWinner              Boolean      @default(false) @map("is_winner")
  createdBy             String?      @map("created_by")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")
  attachments           String[]
  awardedBy             String?      @map("awarded_by")
  awardedDate           DateTime?    @map("awarded_date")
  carrierBenchmark      Json?        @map("carrier_benchmark")
  communicationScore    Int?         @map("communication_score")
  comparisonRank        Int?         @map("comparison_rank")
  expirationDate        DateTime?    @map("expiration_date")
  historicalComparison  Json?        @map("historical_comparison")
  isAwarded             Boolean      @default(false) @map("is_awarded")
  isExpired             Boolean      @default(false) @map("is_expired")
  isVerified            Boolean      @default(false) @map("is_verified")
  marketPosition        String?      @map("market_position")
  marketTrends          Json?        @map("market_trends")
  notes                 String?
  overallScore          Decimal?     @map("overall_score") @db.Decimal(3, 2)
  priceCompetitiveness  Decimal?     @map("price_competitiveness") @db.Decimal(3, 2)
  quoteNumber           String?      @map("quote_number")
  rateOptimization      Json?        @map("rate_optimization")
  receivedDate          DateTime?    @map("received_date")
  rejectionReason       String?      @map("rejection_reason")
  reliability           Int?         @map("reliability")
  responseTime          Int?         @map("response_time")
  serviceQuality        Int?         @map("service_quality")
  tags                  String[]
  verifiedAt            DateTime?    @map("verified_at")
  verifiedBy            String?      @map("verified_by")
  awarder               CompanyUser? @relation("QuoteAwarder", fields: [awardedBy], references: [id])
  contact               Contact      @relation(fields: [contactId], references: [id])
  creator               CompanyUser? @relation(fields: [createdBy], references: [id])
  rfq                   RFQ          @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  shippingLine          ShippingLine @relation(fields: [shippingLineId], references: [id])
  verifier              CompanyUser? @relation("QuoteVerifier", fields: [verifiedBy], references: [id])
  emailReplies          EmailReply[]

  @@map("quotes")
}

model EmailTemplate {
  id              String         @id @default(uuid())
  companyId       String         @map("company_id")
  name            String
  templateType    String         @map("template_type")
  subject         String
  bodyHtml        String         @map("body_html")
  bodyText        String?        @map("body_text")
  supportedTokens String[]       @map("supported_tokens")
  language        String         @default("en")
  isDefault       Boolean        @default(false) @map("is_default")
  isActive        Boolean        @default(true) @map("is_active")
  createdBy       String         @map("created_by")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  emailLogs       EmailLog[]
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator         CompanyUser    @relation(fields: [createdBy], references: [id])
  followUpRules   FollowUpRule[]
  bulkEmails      BulkEmail[]

  @@unique([companyId, name])
  @@map("email_templates")
}

model EmailLog {
  id                    String         @id @default(uuid())
  companyId             String         @map("company_id")
  toEmail               String         @map("to_email")
  fromEmail             String         @map("from_email")
  subject               String
  bodyHtml              String?        @map("body_html")
  bodyText              String?        @map("body_text")
  messageId             String?        @map("message_id")
  status                EmailStatus    @default(QUEUED)
  rfqId                 String?        @map("rfq_id")
  contactId             String?        @map("contact_id")
  templateId            String?        @map("template_id")
  followUpRuleId        String?        @map("follow_up_rule_id")
  scheduledFollowUpId   String?        @map("scheduled_follow_up_id")
  emailType             EmailType      @default(RFQ) @map("email_type")
  priority              EmailPriority  @default(NORMAL) @map("priority")
  queuedAt              DateTime       @default(now()) @map("queued_at")
  sentAt                DateTime?      @map("sent_at")
  deliveredAt           DateTime?      @map("delivered_at")
  openedAt              DateTime?      @map("opened_at")
  clickedAt             DateTime?      @map("clicked_at")
  bouncedAt             DateTime?      @map("bounced_at")
  failedAt              DateTime?      @map("failed_at")
  errorMessage          String?        @map("error_message")
  retryCount            Int            @default(0) @map("retry_count")
  maxRetries            Int            @default(3) @map("max_retries")
  nextRetryAt           DateTime?      @map("next_retry_at")
  personalizationData   Json?          @map("personalization_data")
  trackingPixelId       String?        @map("tracking_pixel_id")
  unsubscribeToken      String?        @map("unsubscribe_token")
  language              String         @default("en")
  timezone              String?        @map("timezone")
  scheduledFor          DateTime?      @map("scheduled_for")
  isBulkEmail           Boolean        @default(false) @map("is_bulk_email")
  bulkEmailId           String?        @map("bulk_email_id")
  campaignId            String?        @map("campaign_id")
  createdAt             DateTime       @default(now()) @map("created_at")
  company               Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact               Contact?       @relation(fields: [contactId], references: [id])
  rfq                   RFQ?           @relation(fields: [rfqId], references: [id])
  template              EmailTemplate? @relation(fields: [templateId], references: [id])
  followUpRule          FollowUpRule?  @relation(fields: [followUpRuleId], references: [id])
  scheduledFollowUp     ScheduledFollowUp? @relation(fields: [scheduledFollowUpId], references: [id])
  bulkEmail             BulkEmail?     @relation(fields: [bulkEmailId], references: [id])
  emailCampaign         EmailCampaign? @relation(fields: [campaignId], references: [id])
  emailEngagements      EmailEngagement[]
  emailBounces          EmailBounce[]

  @@map("email_logs")
}

model FollowUpRule {
  id                 String              @id @default(uuid())
  companyId          String              @map("company_id")
  name               String
  description        String?
  daysAfterSend      Int                 @default(3) @map("days_after_send")
  onlyIfNotOpened    Boolean             @default(false) @map("only_if_not_opened")
  onlyIfNotReplied   Boolean             @default(true) @map("only_if_not_replied")
  maxFollowUps       Int                 @default(2) @map("max_follow_ups")
  emailTemplateId    String?             @map("email_template_id")
  isActive           Boolean             @default(true) @map("is_active")
  
  // Enhanced conditional follow-up features
  onlyIfOpened       Boolean             @default(false) @map("only_if_opened")
  onlyIfClicked      Boolean             @default(false) @map("only_if_clicked")
  onlyIfDelivered    Boolean             @default(false) @map("only_if_delivered")
  minTimeSinceOpen   Int?                @map("min_time_since_open") // hours
  maxTimeSinceOpen   Int?                @map("max_time_since_open") // hours
  
  // Advanced scheduling features
  scheduleType       ScheduleType        @default(IMMEDIATE) @map("schedule_type")
  specificTime       String?             @map("specific_time") // HH:MM format
  timezone           String?             @default("UTC")
  businessDaysOnly   Boolean             @default(false) @map("business_days_only")
  excludeWeekends    Boolean             @default(false) @map("exclude_weekends")
  excludeHolidays    Boolean             @default(false) @map("exclude_holidays")
  
  // Follow-up sequence configuration
  followUpIntervals  Json?               @map("follow_up_intervals") // Array of days for each follow-up
  customSchedule     Json?               @map("custom_schedule") // Custom scheduling rules
  
  createdBy          String              @map("created_by")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator            CompanyUser         @relation(fields: [createdBy], references: [id])
  emailTemplate      EmailTemplate?      @relation(fields: [emailTemplateId], references: [id])
  scheduledFollowUps ScheduledFollowUp[]
  emailLogs          EmailLog[]

  @@map("follow_up_rules")
}

model ScheduledFollowUp {
  id               String         @id @default(uuid())
  rfqId            String         @map("rfq_id")
  contactId        String         @map("contact_id")
  followUpRuleId   String         @map("follow_up_rule_id")
  scheduledAt      DateTime       @map("scheduled_at")
  sentAt           DateTime?      @map("sent_at")
  status           FollowUpStatus @default(SCHEDULED)
  skipReason       String?        @map("skip_reason")
  followUpSequence Int            @default(1) @map("follow_up_sequence")
  
  // Enhanced scheduling and condition tracking
  originalScheduledAt DateTime?   @map("original_scheduled_at")
  rescheduledAt       DateTime?   @map("rescheduled_at")
  rescheduleReason    String?     @map("reschedule_reason")
  conditionMetAt      DateTime?   @map("condition_met_at")
  conditionType       String?     @map("condition_type") // 'opened', 'clicked', 'delivered', etc.
  
  // Timezone and business hours tracking
  timezone           String?      @default("UTC")
  isBusinessHours    Boolean      @default(false) @map("is_business_hours")
  
  createdAt        DateTime       @default(now()) @map("created_at")
  contact          Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  followUpRule     FollowUpRule   @relation(fields: [followUpRuleId], references: [id])
  rfq              RFQ            @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  emailLogs        EmailLog[]

  @@map("scheduled_follow_ups")
}

model BulkEmail {
  id                String         @id @default(uuid())
  companyId         String         @map("company_id")
  name              String
  description       String?
  subject           String
  bodyHtml          String         @map("body_html")
  bodyText          String?        @map("body_text")
  templateId        String?        @map("template_id")
  contactIds        String[]       @map("contact_ids")
