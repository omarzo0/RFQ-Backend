generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==============================================
// AUTHENTICATION & USER MANAGEMENT
// ==============================================

model Admin {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  role          AdminRole @default(ADMIN)
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relationships
  supportTickets SupportTicket[] @relation("AssignedTickets")
  refreshTokens  RefreshToken[]

  @@map("admins")
}

model Company {
  id                   String            @id @default(uuid())
  name                 String
  email                String            @unique
  domain               String?
  phone                String?
  address              String?
  city                 String?
  country              String?
  timezone             String            @default("UTC")
  
  // Subscription & Billing
  subscriptionPlan     String            @default("trial") @map("subscription_plan")
  subscriptionStatus   SubscriptionStatus @default(ACTIVE) @map("subscription_status")
  stripeCustomerId     String?           @map("stripe_customer_id")
  trialEndsAt          DateTime?         @map("trial_ends_at")
  
  // Company Settings
  emailFooter          String?           @map("email_footer")
  defaultFollowUpDays  Int               @default(3) @map("default_follow_up_days")
  autoFollowUpEnabled  Boolean           @default(true) @map("auto_follow_up_enabled")
  
  // Status
  isActive             Boolean           @default(true) @map("is_active")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  // Relationships
  users                CompanyUser[]
  shippingLines        ShippingLine[]
  rfqs                 RFQ[]
  rfqTemplates         RFQTemplate[]
  emailTemplates       EmailTemplate[]
  emailLogs            EmailLog[]
  followUpRules        FollowUpRule[]
  carrierMetrics       CarrierPerformanceMetric[]
  routeMetrics         RoutePerformanceMetric[]
  usageMetrics         UsageMetric[]
  webhookEndpoints     WebhookEndpoint[]
  apiKeys              APIKey[]
  supportTickets       SupportTicket[]
  refreshTokens        RefreshToken[]
  contacts             Contact[]

  @@map("companies")
}

model CompanyUser {
  id          String    @id @default(uuid())
  companyId   String    @map("company_id")
  email       String
  passwordHash String   @map("password_hash")
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  role        UserRole  @default(EMPLOYEE)
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relationships
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdRFQs     RFQ[]           @relation("RFQCreator")
  assignedRFQs    RFQ[]           @relation("RFQAssignee")
  createdShippingLines ShippingLine[]
  createdContacts Contact[]
  createdTemplates RFQTemplate[]
  createdEmailTemplates EmailTemplate[]
  createdFollowUpRules FollowUpRule[]
  createdQuotes   Quote[]
  createdWebhooks WebhookEndpoint[]
  createdAPIKeys  APIKey[]
  refreshTokens   RefreshToken[]

  @@unique([companyId, email])
  @@map("company_users")
}

model RefreshToken {
  id           String    @id @default(uuid())
  tokenHash    String    @map("token_hash")
  
  // Use separate foreign key fields
  adminUserId  String?   @map("admin_user_id")
  companyUserId String?  @map("company_user_id")
  
  userType     UserType  @map("user_type")
  companyId    String?   @map("company_id")
  expiresAt    DateTime  @map("expires_at")
  isRevoked    Boolean   @default(false) @map("is_revoked")
  createdAt    DateTime  @default(now()) @map("created_at")

  // Relationships with separate foreign key fields
  company     Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  admin       Admin?       @relation(fields: [adminUserId], references: [id])
  companyUser CompanyUser? @relation(fields: [companyUserId], references: [id])

  @@map("refresh_tokens")
}

// ==============================================
// SHIPPING & CONTACTS
// ==============================================

model ShippingLine {
  id                   String    @id @default(uuid())
  companyId            String    @map("company_id")
  name                 String
  code                 String?
  website              String?
  headquartersLocation String?   @map("headquarters_location")
  description          String?
  isActive             Boolean   @default(true) @map("is_active")
  isArchived           Boolean   @default(false) @map("is_archived")
  createdBy            String    @map("created_by")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  // Relationships
  company       Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator       CompanyUser                @relation(fields: [createdBy], references: [id])
  contacts      Contact[]
  rfqRecipients RFQRecipient[]
  quotes        Quote[]
  carrierMetrics CarrierPerformanceMetric[]
  routeMetrics  RoutePerformanceMetric[]

  @@unique([companyId, name])
  @@map("shipping_lines")
}

model Contact {
  id               String    @id @default(uuid())
  companyId        String    @map("company_id")
  shippingLineId   String    @map("shipping_line_id")
  firstName        String    @map("first_name")
  lastName         String    @map("last_name")
  email            String
  phone            String?
  jobTitle         String?   @map("job_title")
  department       String?
  tags             String[]
  notes            String?
  performanceScore Int       @default(0) @map("performance_score")
  doNotContact     Boolean   @default(false) @map("do_not_contact")
  isPrimary        Boolean   @default(false) @map("is_primary")
  isActive         Boolean   @default(true) @map("is_active")
  isArchived       Boolean   @default(false) @map("is_archived")
  createdBy        String    @map("created_by")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relationships
  company         Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shippingLine    ShippingLine       @relation(fields: [shippingLineId], references: [id], onDelete: Cascade)
  creator         CompanyUser        @relation(fields: [createdBy], references: [id])
  rfqRecipients   RFQRecipient[]
  quotes          Quote[]
  emailLogs       EmailLog[]
  scheduledFollowUps ScheduledFollowUp[]

  @@unique([companyId, shippingLineId, email])
  @@map("contacts")
}

// ==============================================
// RFQ MANAGEMENT
// ==============================================

model RFQTemplate {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  name                String
  description         String?
  subjectTemplate     String   @map("subject_template")
  bodyTemplate        String   @map("body_template")
  originPort          String?  @map("origin_port")
  destinationPort     String?  @map("destination_port")
  commodity           String?
  containerType       String?  @map("container_type")
  containerQuantity   Int?     @map("container_quantity")
  cargoWeight         Decimal? @map("cargo_weight") @db.Decimal(10,2)
  cargoVolume         Decimal? @map("cargo_volume") @db.Decimal(10,2)
  incoterm            String?
  specialRequirements String?  @map("special_requirements")
  requiredServices    String[] @map("required_services")
  isDefault           Boolean  @default(false) @map("is_default")
  createdBy           String   @map("created_by")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relationships
  company Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator CompanyUser @relation(fields: [createdBy], references: [id])

  @@map("rfq_templates")
}

model RFQ {
  id                  String      @id @default(uuid())
  companyId           String      @map("company_id")
  rfqNumber           String      @map("rfq_number")
  title               String
  description         String?
  originPort          String      @map("origin_port")
  destinationPort     String      @map("destination_port")
  commodity           String?
  containerType       String?     @map("container_type")
  containerQuantity   Int         @default(1) @map("container_quantity")
  cargoWeight         Decimal?    @map("cargo_weight") @db.Decimal(10,2)
  cargoVolume         Decimal?    @map("cargo_volume") @db.Decimal(10,2)
  incoterm            String      @default("FOB")
  cargoReadyDate      DateTime?   @map("cargo_ready_date")
  quoteDeadline       DateTime?   @map("quote_deadline")
  shipmentUrgency     Urgency     @default(NORMAL) @map("shipment_urgency")
  specialRequirements String?     @map("special_requirements")
  requiredServices    String[]    @map("required_services")
  preferredCarriers   String[]    @map("preferred_carriers")
  emailSubject        String?     @map("email_subject")
  emailBody           String?     @map("email_body")
  status              RFQStatus   @default(DRAFT)
  sentAt              DateTime?   @map("sent_at")
  closedAt            DateTime?   @map("closed_at")
  totalContactsSent   Int         @default(0) @map("total_contacts_sent")
  totalQuotesReceived Int         @default(0) @map("total_quotes_received")
  bestQuoteAmount     Decimal?    @map("best_quote_amount") @db.Decimal(12,2)
  averageQuoteAmount  Decimal?    @map("average_quote_amount") @db.Decimal(12,2)
  createdBy           String      @map("created_by")
  assignedTo          String?     @map("assigned_to")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  // Relationships
  company           Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUser     CompanyUser         @relation("RFQCreator", fields: [createdBy], references: [id])
  assignedToUser    CompanyUser?        @relation("RFQAssignee", fields: [assignedTo], references: [id])
  recipients        RFQRecipient[]
  quotes            Quote[]
  emailLogs         EmailLog[]
  scheduledFollowUps ScheduledFollowUp[]

  @@unique([companyId, rfqNumber])
  @@map("rfqs")
}

model RFQRecipient {
  id                     String    @id @default(uuid())
  rfqId                  String    @map("rfq_id")
  contactId              String    @map("contact_id")
  shippingLineId         String    @map("shipping_line_id")
  emailSentAt            DateTime  @map("email_sent_at")
  emailDeliveredAt       DateTime? @map("email_delivered_at")
  emailOpenedAt          DateTime? @map("email_opened_at")
  emailClickedAt         DateTime? @map("email_clicked_at")
  lastEmailActivityAt    DateTime? @map("last_email_activity_at")
  hasResponded           Boolean   @default(false) @map("has_responded")
  responseReceivedAt     DateTime? @map("response_received_at")
  createdAt              DateTime  @default(now()) @map("created_at")

  // Relationships
  rfq          RFQ          @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  shippingLine ShippingLine @relation(fields: [shippingLineId], references: [id], onDelete: Cascade)

  @@unique([rfqId, contactId])
  @@map("rfq_recipients")
}

// ==============================================
// QUOTE MANAGEMENT
// ==============================================

model Quote {
  id                   String       @id @default(uuid())
  rfqId                String       @map("rfq_id")
  contactId            String       @map("contact_id")
  shippingLineId       String       @map("shipping_line_id")
  quoteReference       String?      @map("quote_reference")
  oceanFreight         Decimal?     @map("ocean_freight") @db.Decimal(12,2)
  currency             String       @default("USD")
  baf                  Decimal?     @db.Decimal(12,2)
  caf                  Decimal?     @db.Decimal(12,2)
  securityFee          Decimal?     @map("security_fee") @db.Decimal(12,2)
  documentationFee     Decimal?     @map("documentation_fee") @db.Decimal(12,2)
  handlingCharges      Decimal?     @map("handling_charges") @db.Decimal(12,2)
  otherCharges         Json?        @map("other_charges")
  totalAmount          Decimal      @map("total_amount") @db.Decimal(12,2)
  validityDate         DateTime     @map("validity_date")
  paymentTerms         String?      @map("payment_terms")
  transitTime          String?      @map("transit_time")
  freeTimeAtOrigin     Int?         @map("free_time_at_origin")
  freeTimeAtDestination Int?        @map("free_time_at_destination")
  termsAndConditions   String?      @map("terms_and_conditions")
  specialNotes         String?      @map("special_notes")
  source               QuoteSource  @default(EMAIL)
  isParsedByAi         Boolean      @default(false) @map("is_parsed_by_ai")
  confidenceScore      Decimal?     @map("confidence_score") @db.Decimal(3,2)
  rawEmailContent      String?      @map("raw_email_content")
  status               QuoteStatus  @default(ACTIVE)
  isWinner             Boolean      @default(false) @map("is_winner")
  createdBy            String?      @map("created_by")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  // Relationships
  rfq          RFQ          @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id])
  shippingLine ShippingLine @relation(fields: [shippingLineId], references: [id])
  creator      CompanyUser? @relation(fields: [createdBy], references: [id])

  @@map("quotes")
}

// ==============================================
// EMAIL SYSTEM
// ==============================================

model EmailTemplate {
  id               String    @id @default(uuid())
  companyId        String    @map("company_id")
  name             String
  templateType     String    @map("template_type")
  subject          String
  bodyHtml         String    @map("body_html")
  bodyText         String?   @map("body_text")
  supportedTokens  String[]  @map("supported_tokens")
  language         String    @default("en")
  isDefault        Boolean   @default(false) @map("is_default")
  isActive         Boolean   @default(true) @map("is_active")
  createdBy        String    @map("created_by")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relationships
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator       CompanyUser   @relation(fields: [createdBy], references: [id])
  emailLogs     EmailLog[]
  followUpRules FollowUpRule[]

  @@unique([companyId, name])
  @@map("email_templates")
}

model EmailLog {
  id           String      @id @default(uuid())
  companyId    String      @map("company_id")
  toEmail      String      @map("to_email")
  fromEmail    String      @map("from_email")
  subject      String
  bodyHtml     String?     @map("body_html")
  bodyText     String?     @map("body_text")
  messageId    String?     @map("message_id")
  status       EmailStatus @default(QUEUED)
  rfqId        String?     @map("rfq_id")
  contactId    String?     @map("contact_id")
  templateId   String?     @map("template_id")
  queuedAt     DateTime    @default(now()) @map("queued_at")
  sentAt       DateTime?   @map("sent_at")
  deliveredAt  DateTime?   @map("delivered_at")
  openedAt     DateTime?   @map("opened_at")
  clickedAt    DateTime?   @map("clicked_at")
  bouncedAt    DateTime?   @map("bounced_at")
  failedAt     DateTime?   @map("failed_at")
  errorMessage String?     @map("error_message")
  retryCount   Int         @default(0) @map("retry_count")
  createdAt    DateTime    @default(now()) @map("created_at")

  // Relationships
  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rfq       RFQ?           @relation(fields: [rfqId], references: [id])
  contact   Contact?       @relation(fields: [contactId], references: [id])
  template  EmailTemplate? @relation(fields: [templateId], references: [id])

  @@map("email_logs")
}

// ==============================================
// AUTOMATED FOLLOW-UPS
// ==============================================

model FollowUpRule {
  id                String    @id @default(uuid())
  companyId         String    @map("company_id")
  name              String
  description       String?
  daysAfterSend     Int       @default(3) @map("days_after_send")
  onlyIfNotOpened   Boolean   @default(false) @map("only_if_not_opened")
  onlyIfNotReplied  Boolean   @default(true) @map("only_if_not_replied")
  maxFollowUps      Int       @default(2) @map("max_follow_ups")
  emailTemplateId   String?   @map("email_template_id")
  isActive          Boolean   @default(true) @map("is_active")
  createdBy         String    @map("created_by")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relationships
  company           Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  emailTemplate     EmailTemplate?      @relation(fields: [emailTemplateId], references: [id])
  creator           CompanyUser         @relation(fields: [createdBy], references: [id])
  scheduledFollowUps ScheduledFollowUp[]

  @@map("follow_up_rules")
}

model ScheduledFollowUp {
  id               String            @id @default(uuid())
  rfqId            String            @map("rfq_id")
  contactId        String            @map("contact_id")
  followUpRuleId   String            @map("follow_up_rule_id")
  scheduledAt      DateTime          @map("scheduled_at")
  sentAt           DateTime?         @map("sent_at")
  status           FollowUpStatus    @default(SCHEDULED)
  skipReason       String?           @map("skip_reason")
  followUpSequence Int               @default(1) @map("follow_up_sequence")
  createdAt        DateTime          @default(now()) @map("created_at")

  // Relationships
  rfq            RFQ          @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  contact        Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  followUpRule   FollowUpRule @relation(fields: [followUpRuleId], references: [id])

  @@map("scheduled_follow_ups")
}

// ==============================================
// ANALYTICS & REPORTING
// ==============================================

model CarrierPerformanceMetric {
  id                      String   @id @default(uuid())
  companyId               String   @map("company_id")
  shippingLineId          String   @map("shipping_line_id")
  periodStart             DateTime @map("period_start")
  periodEnd               DateTime @map("period_end")
  periodType              String   @map("period_type")
  rfqsReceived            Int      @default(0) @map("rfqs_received")
  quotesSubmitted         Int      @default(0) @map("quotes_submitted")
  responseRate            Decimal  @default(0) @map("response_rate") @db.Decimal(5,2)
  averageResponseTimeHours Decimal? @map("average_response_time_hours") @db.Decimal(8,2)
  quotesWon               Int      @default(0) @map("quotes_won")
  winRate                 Decimal  @default(0) @map("win_rate") @db.Decimal(5,2)
  averageQuoteAmount      Decimal? @map("average_quote_amount") @db.Decimal(12,2)
  calculatedAt            DateTime @default(now()) @map("calculated_at")

  // Relationships
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shippingLine ShippingLine @relation(fields: [shippingLineId], references: [id], onDelete: Cascade)

  @@unique([companyId, shippingLineId, periodStart, periodEnd, periodType])
  @@map("carrier_performance_metrics")
}

model RoutePerformanceMetric {
  id                        String       @id @default(uuid())
  companyId                 String       @map("company_id")
  originPort                String       @map("origin_port")
  destinationPort           String       @map("destination_port")
  periodStart               DateTime     @map("period_start")
  periodEnd                 DateTime     @map("period_end")
  periodType                String       @map("period_type")
  totalRFQs                 Int          @default(0) @map("total_rfqs")
  totalQuotes               Int          @default(0) @map("total_quotes")
  averageQuoteAmount        Decimal?     @map("average_quote_amount") @db.Decimal(12,2)
  lowestQuoteAmount         Decimal?     @map("lowest_quote_amount") @db.Decimal(12,2)
  highestQuoteAmount        Decimal?     @map("highest_quote_amount") @db.Decimal(12,2)
  mostCompetitiveCarrierId  String?      @map("most_competitive_carrier_id")
  calculatedAt              DateTime     @default(now()) @map("calculated_at")

  // Relationships
  company                   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  mostCompetitiveCarrier    ShippingLine? @relation(fields: [mostCompetitiveCarrierId], references: [id])

  @@unique([companyId, originPort, destinationPort, periodStart, periodEnd, periodType])
  @@map("route_performance_metrics")
}

// ==============================================
// SYSTEM FEATURES & BILLING
// ==============================================

model SystemFeature {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  featureKey  String      @unique @map("feature_key")
  featureType FeatureType @map("feature_type")
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")

  @@map("system_features")
}

model SubscriptionPlan {
  id                     String  @id @default(uuid())
  name                   String
  description            String?
  priceMonthly           Decimal? @map("price_monthly") @db.Decimal(10,2)
  priceYearly            Decimal? @map("price_yearly") @db.Decimal(10,2)
  maxUsers               Int?     @map("max_users")
  maxRFQsPerMonth        Int?     @map("max_rfqs_per_month")
  maxContacts            Int?     @map("max_contacts")
  maxEmailSendsPerMonth  Int?     @map("max_email_sends_per_month")
  features               Json?
  isActive               Boolean  @default(true) @map("is_active")
  createdAt              DateTime @default(now()) @map("created_at")

  @@map("subscription_plans")
}

model UsageMetric {
  id                 String   @id @default(uuid())
  companyId          String   @map("company_id")
  periodMonth        Int      @map("period_month")
  periodYear         Int      @map("period_year")
  rfqsCreated        Int      @default(0) @map("rfqs_created")
  emailsSent         Int      @default(0) @map("emails_sent")
  aiParsingRequests  Int      @default(0) @map("ai_parsing_requests")
  apiCalls           Int      @default(0) @map("api_calls")
  fileStorageMb      Decimal  @default(0) @map("file_storage_mb") @db.Decimal(10,2)
  lastUpdatedAt      DateTime @default(now()) @map("last_updated_at")

  // Relationships
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodMonth, periodYear])
  @@map("usage_metrics")
}

// ==============================================
// INTEGRATIONS & API
// ==============================================

model WebhookEndpoint {
  id            String    @id @default(uuid())
  companyId     String    @map("company_id")
  name          String
  url           String
  secret        String?
  events        String[]
  isActive      Boolean   @default(true) @map("is_active")
  lastSuccessAt DateTime? @map("last_success_at")
  lastFailureAt DateTime? @map("last_failure_at")
  failureCount  Int       @default(0) @map("failure_count")
  createdBy     String    @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relationships
  company Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator CompanyUser @relation(fields: [createdBy], references: [id])

  @@map("webhook_endpoints")
}

model APIKey {
  id               String    @id @default(uuid())
  companyId        String    @map("company_id")
  keyName          String    @map("key_name")
  apiKey           String    @unique @map("api_key")
  scopes           String[]
  rateLimitPerHour Int       @default(1000) @map("rate_limit_per_hour")
  isActive         Boolean   @default(true) @map("is_active")
  lastUsedAt       DateTime? @map("last_used_at")
  expiresAt        DateTime? @map("expires_at")
  createdBy        String    @map("created_by")
  createdAt        DateTime  @default(now()) @map("created_at")

  // Relationships
  company Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator CompanyUser @relation(fields: [createdBy], references: [id])

  @@map("api_keys")
}

// ==============================================
// SUPPORT SYSTEM
// ==============================================

model SupportTicket {
  id          String        @id @default(uuid())
  companyId   String?       @map("company_id")
  userId      String?       @map("user_id")
  userType    UserType?     @map("user_type")
  title       String
  description String
  priority    TicketPriority @default(NORMAL)
  category    String?
  status      TicketStatus  @default(OPEN)
  assignedTo  String?       @map("assigned_to")
  createdAt   DateTime      @default(now()) @map("created_at")
  resolvedAt  DateTime?     @map("resolved_at")
  closedAt    DateTime?     @map("closed_at")

  // Relationships
  company      Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assignedAdmin Admin?   @relation("AssignedTickets", fields: [assignedTo], references: [id])

  @@map("support_tickets")
}

